# Stage 1: Download pre-built Wine-TKG with WoW64 support
FROM registry.fedoraproject.org/fedora-minimal:44 AS wine-downloader

ARG WINE_TKG_VERSION=11.11
ARG WINE_TKG_URL=https://github.com/Kron4ek/Wine-Builds/releases/download/${WINE_TKG_VERSION}/wine-${WINE_TKG_VERSION}-staging-tkg-amd64-wow64.tar.xz

RUN microdnf install -y --nodocs curl xz tar && microdnf clean all
RUN curl -fsSL "$WINE_TKG_URL" | tar xJ -C /opt && \
    mv /opt/wine-${WINE_TKG_VERSION}-staging-tkg-amd64-wow64 /opt/wine

# Stage 2: Runtime image
FROM registry.fedoraproject.org/fedora-minimal:44

# Copy Wine-TKG from downloader
COPY --from=wine-downloader /opt/wine /usr/local

# Runtime dependencies for Wine + Xvfb
RUN microdnf install -y --nodocs \
    libX11 libXext libXcursor libXi libXrandr libXinerama libXcomposite \
    libXrender mesa-libGL freetype fontconfig gnutls libpng libjpeg-turbo \
    pulseaudio-libs alsa-lib SDL2 libusb1 dbus-libs \
    glibc.i686 freetype.i686 fontconfig.i686 libX11.i686 libXext.i686 \
    libXcursor.i686 libXi.i686 libXrandr.i686 libXinerama.i686 \
    libXcomposite.i686 libXrender.i686 mesa-libGL.i686 \
    gnutls.i686 libpng.i686 \
    xorg-x11-server-Xvfb xdpyinfo \
    winetricks cabextract curl \
    tini \
    && microdnf clean all

ENV WINEPREFIX=/wine-prefix
ENV DISPLAY=:99
# Suppress Wine debug output and skip Wine Mono download.
# WINEDEBUG=-all prevents Wine from spamming fixme/warn lines.
# mscoree=d disables Wine's .NET/Mono — BepInEx brings its own runtime.
ENV WINEDEBUG=-all
ENV WINEDLLOVERRIDES="mscoree=d;winhttp=n,b"

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["/entrypoint.sh"]
