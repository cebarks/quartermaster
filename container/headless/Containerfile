# Stage 1: Build Wine 11 from source with ntsync + WoW64 support
# Using Debian bookworm for the builder — multilib cross-compilation
# is well-supported and the build environment is proven.
FROM debian:bookworm AS wine-builder

ARG WINE_VERSION=11.0

RUN dpkg --add-architecture i386 && apt-get update && \
    apt-get install -y --no-install-recommends \
    gcc g++ gcc-multilib g++-multilib make flex bison \
    pkg-config curl ca-certificates xz-utils \
    gcc-mingw-w64-x86-64 g++-mingw-w64-x86-64 \
    gcc-mingw-w64-i686 g++-mingw-w64-i686 \
    libfreetype6-dev libfreetype6-dev:i386 \
    libx11-dev libx11-dev:i386 \
    libxcursor-dev libxcursor-dev:i386 \
    libxi-dev libxi-dev:i386 \
    libxext-dev libxext-dev:i386 \
    libxrandr-dev libxrandr-dev:i386 \
    libxinerama-dev libxinerama-dev:i386 \
    libxcomposite-dev libxcomposite-dev:i386 \
    libxrender-dev libxrender-dev:i386 \
    libgl-dev \
    libfontconfig-dev libfontconfig-dev:i386 \
    libgnutls28-dev libgnutls28-dev:i386 \
    libpng-dev libpng-dev:i386 \
    libjpeg-dev \
    libpulse-dev libpulse-dev:i386 \
    libasound2-dev libasound2-dev:i386 \
    libdbus-1-dev libdbus-1-dev:i386 \
    libusb-1.0-0-dev \
    libsdl2-dev \
    gettext \
    && rm -rf /var/lib/apt/lists/*

# Fetch ntsync.h from upstream kernel (Debian bookworm headers are too old)
RUN curl --create-dirs -fsSL \
    -o /usr/include/linux/ntsync.h \
    https://raw.githubusercontent.com/torvalds/linux/v6.14/include/uapi/linux/ntsync.h

WORKDIR /build
RUN curl -fsSL "https://dl.winehq.org/wine/source/11.0/wine-${WINE_VERSION}.tar.xz" \
    | tar xJ --strip-components=1

# Wine 11 WoW64 build — single binary that handles both 64-bit and 32-bit.
# MinGW cross-compilers build the PE DLLs (kernel32.dll etc.).
# ntsync is auto-detected from the kernel header we installed.
RUN ./configure \
    --prefix=/usr/local \
    --with-x \
    --with-freetype \
    --with-gnutls \
    --with-fontconfig \
    --with-pulse \
    --without-wayland \
    && make -j$(nproc) \
    && make install DESTDIR=/wine-install

# Stage 2: Runtime image
FROM registry.fedoraproject.org/fedora-minimal:44

# Copy Wine from builder
COPY --from=wine-builder /wine-install/usr/local /usr/local

# Runtime dependencies for Wine + Xvfb
RUN microdnf install -y --nodocs \
    libX11 libXext libXcursor libXi libXrandr libXinerama libXcomposite \
    libXrender mesa-libGL freetype fontconfig gnutls libpng libjpeg-turbo \
    pulseaudio-libs alsa-lib SDL2 libusb1 dbus-libs \
    glibc.i686 freetype.i686 fontconfig.i686 libX11.i686 libXext.i686 \
    libXcursor.i686 libXi.i686 libXrandr.i686 libXinerama.i686 \
    libXcomposite.i686 libXrender.i686 mesa-libGL.i686 \
    gnutls.i686 libpng.i686 \
    xorg-x11-server-Xvfb xdpyinfo \
    winetricks cabextract \
    tini \
    && microdnf clean all

ENV WINEPREFIX=/wine-prefix
ENV DISPLAY=:99
# Suppress Wine debug output and skip Wine Mono download.
# WINEDEBUG=-all prevents Wine from spamming fixme/warn lines.
# mscoree=d disables Wine's .NET/Mono — BepInEx brings its own runtime.
ENV WINEDEBUG=-all
ENV WINEDLLOVERRIDES=mscoree=d

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["/entrypoint.sh"]
